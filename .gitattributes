# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf
*.spec text eol=lf

# JSON files
*.json text eol=lf

# Markdown
*.md text eol=lf

# Config files
*.txt text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Windows batch files
*.bat text eol=crlf

# Shell scripts
*.sh text eol=lf
